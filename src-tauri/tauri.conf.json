{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Zenith",
  "version": "0.0.1",
  "identifier": "com.zenith.dev",
"build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix web", 
    "beforeBuildCommand": "npm run build --prefix web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zenith",
        "width": 1200,
        "height": 800,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "visible": false  
      },
      {
        "label": "splashscreen",
        "title": "Cargando...",
        "url": "splashscreen.html",
        "width": 400,
        "height": 300,
        "decorations": false,
        "center": true,
        "resizable": false,
        "alwaysOnTop": true,
        "transparent": true,
        "visible": true 
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/api"
    ],
    "resources": []
  }
}